# PORT CONFIGURATION
# Signaling Server WebSocket port
SIGNALING_PORT=4000
SIGNALING_HOST=localhost

# VIDEO QUALITY (Streamer)
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=60

# ENCODER SETTINGS
# Options: 'copy' (hardware), 'libx264' (software), 'auto' (browser selects)
VIDEO_ENCODER=auto
VIDEO_BITRATE_MAX=15000000
VIDEO_BITRATE_MIN=2000000

# LOGGING
LOG_LEVEL=info
DEBUG=false

# PERFORMANCE
MAX_VIEWERS_PER_STREAMER=10
ICE_CANDIDATE_POOL_SIZE=10

# OPTIONAL: For cloud deployment
# SIGNALING_HOST=your-server.com
# SIGNALING_PORT=443  (if using HTTPS/WSS)
