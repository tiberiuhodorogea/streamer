{
  "name": "p2p-streaming-poc",
  "version": "0.1.0",
  "description": "Fast P2P streaming application - POC",
  "private": true,
  "workspaces": [
    "signaling-server",
    "streamer-app",
    "web-client",
    "shared"
  ],
  "scripts": {
    "install": "npm install --workspaces",
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "build:mediasoup-client": "npx esbuild --bundle --format=iife --global-name=mediasoupClient --platform=browser --minify mediasoup-client --outfile=web-client/mediasoup-client.min.js && node -e \"require('fs').copyFileSync('web-client/mediasoup-client.min.js','streamer-app/src/ui/mediasoup-client.min.js')\"",
    "start:signaling": "npm start --workspace=signaling-server",
    "start:streamer": "npm start --workspace=streamer-app",
    "start:web": "npm start --workspace=web-client"
  },
  "keywords": [
    "p2p",
    "streaming",
    "webrtc",
    "gaming"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.4",
    "mediasoup-client": "^3.18.7"
  }
}
